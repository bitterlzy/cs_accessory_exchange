generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===== 用户 =====
model User {
  id              BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  email           String       @unique @db.VarChar(255)
  username        String       @unique @db.VarChar(50)
  passwordHash    String       @map("password_hash") @db.VarChar(255)
  avatarUrl       String?      @map("avatar_url") @db.VarChar(500)
  steamId         String?      @unique @map("steam_id") @db.VarChar(64)
  reputationScore Int          @default(0) @map("reputation_score")
  tradeCount      Int          @default(0) @map("trade_count")
  status          UserStatus   @default(active)
  lastLogin       DateTime?    @map("last_login")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  inventoryItems  InventoryItem[]
  listings        Listing[]
  listingTracking ListingTracking[]
  proposedOffers  TradeOffer[]     @relation("Proposer")
  receivedOffers  TradeOffer[]     @relation("Receiver")
  eventLogs       EventLog[]
  notifications   Notification[]

  @@map("users")
}

enum UserStatus {
  active
  disabled

  @@map("user_status")
}

// ===== 装备数据字典 =====
model ItemDefinition {
  id                  BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  name                String             @db.VarChar(255)
  category            ItemCategory
  weaponType          String?            @map("weapon_type") @db.VarChar(100)
  skinName            String?            @map("skin_name") @db.VarChar(255)
  rarity              ItemRarity
  rarityColor         String?            @map("rarity_color") @db.Char(7)
  collection          String?            @db.VarChar(255)
  marketHashName      String             @unique @map("market_hash_name") @db.VarChar(255)
  inspectUrlTemplate  String?            @map("inspect_url_template") @db.Text
  imageUrl            String?            @map("image_url") @db.VarChar(500)
  isTradable          Boolean            @default(true) @map("is_tradable")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  inventoryItems     InventoryItem[]
  listingTracking    ListingTracking[]
  itemPrices         ItemPrice[]
  listingsWanted     Listing[]          @relation("WantDefinition")

  @@map("item_definitions")
}

enum ItemCategory {
  weapon
  knife
  gloves
  sticker
  agent
  case
  key
  other

  @@map("item_category")
}

enum ItemRarity {
  consumer
  industrial
  mil_spec
  restricted
  classified
  covert
  special
  exceedingly_rare

  @@map("item_rarity")
}

// ===== 用户库存 =====
model InventoryItem {
  id              BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  ownerId         BigInt           @map("owner_id") @db.UnsignedBigInt
  definitionId    BigInt           @map("definition_id") @db.UnsignedBigInt
  quality         ItemQuality
  floatValue      Decimal?         @map("float_value") @db.Decimal(10, 8)
  pattern         Int?             @db.UnsignedInt
  stickerDetails  Json?            @map("sticker_details")
  statTrak        Boolean          @default(false) @map("stat_trak")
  souvenir        Boolean          @default(false)
  description     String?          @db.Text
  imageUrl        String?          @map("image_url") @db.VarChar(500)
  status          InventoryStatus  @default(available)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  owner          User          @relation(fields: [ownerId], references: [id])
  definition     ItemDefinition @relation(fields: [definitionId], references: [id])
  listing        Listing?
  offerItems     OfferItem[]

  @@index([ownerId])
  @@index([definitionId])
  @@index([ownerId, status])
  @@index([definitionId, quality])
  @@map("inventory_items")
}

enum ItemQuality {
  FN
  MW
  FT
  WW
  BS

  @@map("item_quality")
}

enum InventoryStatus {
  available
  locked
  traded
  removed

  @@map("inventory_status")
}

// ===== 交换请求 (Listing) =====
model Listing {
  id                        BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  sellerId                  BigInt              @map("seller_id") @db.UnsignedBigInt
  offeredItemId             BigInt              @map("offered_item_id") @db.UnsignedBigInt
  wantDescription           String?             @map("want_description") @db.Text
  wantCategory              String?             @map("want_category") @db.VarChar(50)
  wantSpecificDefinitionId  BigInt?             @map("want_specific_definition_id") @db.UnsignedBigInt
  wantQuality               String?             @default("any") @map("want_quality") @db.VarChar(10)
  status                    ListingStatus       @default(active)
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @updatedAt @map("updated_at")

  seller                  User             @relation(fields: [sellerId], references: [id])
  offeredItem             InventoryItem    @relation(fields: [offeredItemId], references: [id])
  wantSpecificDefinition  ItemDefinition?  @relation("WantDefinition", fields: [wantSpecificDefinitionId], references: [id])
  tradeOffers             TradeOffer[]
  listingTracking         ListingTracking?

  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@map("listings")
}

enum ListingStatus {
  active
  matched
  closed
  cancelled

  @@map("listing_status")
}

// ===== 上架跟踪表 =====
model ListingTracking {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  definitionId  BigInt   @map("definition_id") @db.UnsignedBigInt
  userId        BigInt   @map("user_id") @db.UnsignedBigInt
  listingId     BigInt   @unique @map("listing_id") @db.UnsignedBigInt
  status        TrackingStatus @default(active)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  definition  ItemDefinition @relation(fields: [definitionId], references: [id])
  user        User           @relation(fields: [userId], references: [id])
  listing     Listing        @relation(fields: [listingId], references: [id])

  @@index([definitionId, status])
  @@index([userId, status])
  @@map("listing_tracking")
}

enum TrackingStatus {
  active
  inactive

  @@map("tracking_status")
}

// ===== 饰品价格参考 =====
model ItemPrice {
  id            BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  definitionId  BigInt       @map("definition_id") @db.UnsignedBigInt
  quality       ItemQuality
  statTrak      Boolean      @default(false) @map("stat_trak")
  source        PriceSource
  priceMin      Decimal?     @map("price_min") @db.Decimal(12, 2)
  priceMax      Decimal?     @map("price_max") @db.Decimal(12, 2)
  priceAvg      Decimal?     @map("price_avg") @db.Decimal(12, 2)
  volume24h     Int?         @map("volume_24h")
  currency      String       @default("CNY") @db.VarChar(3)
  fetchedAt     DateTime     @map("fetched_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  definition ItemDefinition @relation(fields: [definitionId], references: [id])

  @@index([definitionId])
  @@index([source])
  @@index([fetchedAt])
  @@index([definitionId, quality, statTrak, fetchedAt])
  @@map("item_prices")
}

enum PriceSource {
  steam
  buff
  igxe
  youpin
  other

  @@map("price_source")
}

// ===== 交换提议 =====
model TradeOffer {
  id            BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  listingId     BigInt          @map("listing_id") @db.UnsignedBigInt
  proposerId    BigInt          @map("proposer_id") @db.UnsignedBigInt
  receiverId    BigInt          @map("receiver_id") @db.UnsignedBigInt
  status        OfferStatus     @default(pending)
  proposerNote  String?         @map("proposer_note") @db.Text
  receiverNote  String?         @map("receiver_note") @db.Text
  expiresAt     DateTime?       @map("expires_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  listing     Listing      @relation(fields: [listingId], references: [id])
  proposer    User         @relation("Proposer", fields: [proposerId], references: [id])
  receiver    User         @relation("Receiver", fields: [receiverId], references: [id])
  offerItems  OfferItem[]
  eventLogs   EventLog[]

  @@index([listingId])
  @@index([proposerId])
  @@index([receiverId])
  @@index([status])
  @@map("trade_offers")
}

enum OfferStatus {
  pending
  accepted
  rejected
  countered
  cancelled
  confirmed
  completed

  @@map("offer_status")
}

// ===== 提议物品 =====
model OfferItem {
  id              BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  tradeOfferId    BigInt  @map("trade_offer_id") @db.UnsignedBigInt
  inventoryItemId BigInt  @map("inventory_item_id") @db.UnsignedBigInt
  side            OfferSide
  createdAt       DateTime @default(now()) @map("created_at")

  tradeOffer    TradeOffer    @relation(fields: [tradeOfferId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([tradeOfferId])
  @@map("offer_items")
}

enum OfferSide {
  proposer
  receiver

  @@map("offer_side")
}

// ===== 审计日志 =====
model EventLog {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  tradeOfferId  BigInt?  @map("trade_offer_id") @db.UnsignedBigInt
  actorId       BigInt   @map("actor_id") @db.UnsignedBigInt
  eventType     String   @map("event_type") @db.VarChar(50)
  metadata      Json?
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  createdAt     DateTime @default(now()) @map("created_at")

  tradeOffer TradeOffer? @relation(fields: [tradeOfferId], references: [id])
  actor      User        @relation(fields: [actorId], references: [id])

  @@index([tradeOfferId])
  @@index([eventType])
  @@index([createdAt])
  @@map("event_logs")
}

// ===== 通知 =====
model Notification {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt   @map("user_id") @db.UnsignedBigInt
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  body      String?  @db.Text
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}
